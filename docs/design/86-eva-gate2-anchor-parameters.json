  "interval": {
    "target": "beta_truth_primary_only",
    "level": 0.95,
    "method": "joint_negative_EVA_Hessian_Schur_complement_over_variational_coordinates_then_MASS_ginv",
    "partition": {
      "model_coordinates": ["beta", "theta_rr"],
      "variational_coordinates": ["a", "log_A_diag", "A_off"]
    },
    "symmetrise_before_ginv": true,
    "ginv_tolerance": 1.4901161193847656e-08,
    "algorithm": "H is the symmetric Hessian of negative_EVA at the selected healthy winner. Partition H as [[A, B], [t(B), D]] using the listed coordinate blocks. Require finite H and a successful symmetric positive-definite Cholesky solve for D. Form I = A - B D_inverse t(B), symmetrise I, then V_model = MASS::ginv(I, tol = ginv_tolerance). V_beta is its primary-beta block.",
    "failure_rule": "nonfinite_H_or_failed_SPD_D_solve_or_material_negative_curvature_or_nonfinite_or_nonpositive_beta_variance_is_fit_failure"
  },
