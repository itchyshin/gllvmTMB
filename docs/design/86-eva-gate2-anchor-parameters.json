      "nlminb_eval_max": 2000,
      "nlminb_iter_max": 2000,
      "bfgs_maxit": 500,
      "bfgs_reltol": 1e-12,
      "deterministic_parameter_rules": {
        "beta": "lm.fit(X, qlogis((y + 0.5) / 2)) coefficients, falling back to zero if nonfinite",
        "theta_rr_start_1": "diagonal = 0.10 * c(1, -1); strict lower = zero",
        "theta_rr_start_2_to_4": "diagonal scales = c(-0.10, 0.20, -0.20) times c(1, -1); strict lower = 0.01 * start_id * sin(seq_along(strict_lower))",
