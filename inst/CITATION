    person("Shinichi", "Nakagawa")
  ),
  year     = "in prep",
  note     = "R package version 0.2.0",
  url      = "https://itchyshin.github.io/gllvmTMB",
  textVersion = paste(
    "Nakagawa S (in prep).",
